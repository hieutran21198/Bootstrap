# Local Zitadel scaffold — copy to .env and adjust before `docker compose up`.
# See docs/adrs/0006-zitadel-identity-auth.md for the decision and context.

# --- Pinned image tags ------------------------------------------------------
ZITADEL_VERSION=v4.13.0

# --- Domain and external URL ------------------------------------------------
ZITADEL_DOMAIN=localhost
ZITADEL_EXTERNALPORT=8080
ZITADEL_EXTERNALSECURE=false
ZITADEL_PUBLIC_SCHEME=http

# --- Security / bootstrap ---------------------------------------------------

# 32-char encryption key for data at rest. IMMUTABLE after first init —
# changing it loses access to encrypted data. Generate with:
#   tr -dc A-Za-z0-9 </dev/urandom | head -c 32
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters

# --- Database ---------------------------------------------------------------

ZITADEL_DATABASE_POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/zitadel?sslmode=disable

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=zitadel

# --- First instance (created on first boot) ---------------------------------

# Admin login is <USERNAME>@zitadel.<ZITADEL_DOMAIN>, e.g. admin@zitadel.localhost
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_USERNAME=admin
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_EMAIL_ADDRESS=admin@example.com
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORD=Password1!
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORDCHANGEREQUIRED=false
